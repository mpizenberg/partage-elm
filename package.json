{
  "name": "partage",
  "private": true,
  "type": "module",
  "scripts": {
    "i18n": "travelm-agency translations --elm_path=src/Translations.elm --inline",
    "prepare:dist": "rimraf dist && shx mkdir dist",
    "bundle:html": "shx cp public/index.html dist/",
    "bundle:assets": "shx cp public/manifest.webmanifest public/*.svg public/icon-*.png dist/",
    "bundle:js": "esbuild public/index.js --bundle --outfile=dist/index.js --format=iife --define:__PB_URL__=\\\"${PB_URL:-http://127.0.0.1:8090}\\\"",
    "make": "elm-watch make",
    "pwa": "node build-sw.mjs",
    "prebuild": "pnpm i18n && pnpm prepare:dist && pnpm bundle:html && pnpm bundle:js && pnpm bundle:assets",
    "build": "pnpm prebuild && elm-watch make && pnpm pwa",
    "build:optimize": "pnpm prebuild && elm-watch make --optimize && pnpm pwa",
    "watch:html": "watchexec -w public/index.html -- pnpm bundle:html",
    "watch:js": "esbuild public/index.js --bundle --outfile=dist/index.js --format=iife --define:__PB_URL__=\\\"${PB_URL:-http://127.0.0.1:8090}\\\" --watch",
    "watch:i18n": "watchexec -w translations -- pnpm i18n",
    "watch:pwa": "watchexec -w public/*.webmanifest -w build-sw.mjs -- pnpm pwa",
    "dev": "pnpm prebuild && pnpm pwa && run-pty % pnpm -F pb_server serve --dev % elm-watch hot % pnpm watch:html % pnpm watch:js % pnpm watch:i18n % pnpm watch:pwa",
    "test": "elm-test",
    "format": "elm-format --yes src/ tests/ review/",
    "format:check": "elm-format src/ tests/ review/ --validate",
    "lint": "elm-review",
    "postinstall": "elm-tooling install"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "elm-review": "^2.13.5",
    "elm-test": "^0.19.1-revision17",
    "elm-tooling": "^1.17.0",
    "elm-watch": "2.0.0-beta.12",
    "esbuild": "^0.27.3",
    "rimraf": "^6.1.3",
    "run-pty": "^6.0.2",
    "shx": "^0.4.0",
    "travelm-agency": "^3.8.0"
  },
  "dependencies": {
    "@andrewmacmurray/elm-concurrent-task": "^2.0.0",
    "pocketbase": "^0.26.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
